import React, { useState } from "react";
import { useTransferenciasStore } from "../store/TransferenciasStore";
import { RegistrarTransferencia } from "../components/organismos/formularios/RegistrarTransferencia";
import { useQuery, useQueryClient } from "@tanstack/react-query";
import { toast } from "sonner";

export const Transferencias = () => {
  const store = useTransferenciasStore();
  const [openForm, setOpenForm] = useState(false);
  const queryClient = useQueryClient();

  const { isLoading } = useQuery({
    queryKey: ["historialTransferencias"],
    queryFn: async () => {
      await store.mostrarTransferencias();
      return true;
    }
  });

  const handleRecibir = async (id) => {
    try {
      await store.recibirTransferencia(id);
      toast.success("¡Mercancía recibida e inventario actualizado!");
      queryClient.invalidateQueries(["historialTransferencias"]);
    } catch (e) { toast.error(e.message); }
  };

  const handleEliminar = async (id) => {
    if (window.confirm(`¿Estás seguro de que deseas eliminar la transferencia #${id}?`)) {
      try {
        await store.eliminarTransferencia(id);
        toast.success("Transferencia eliminada por completo.");
        queryClient.invalidateQueries(["historialTransferencias"]);
      } catch (e) { toast.error(e.message); }
    }
  };

  const handleEditar = async (item) => {
    await store.prepararEdicion(item);
    setOpenForm(true);
  };

  return (
    <div style={{ padding: "30px" }}>
      <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: "20px" }}>
        <h1 style={{ color: "#2c3e50", margin: 0 }}>Gestión de Transferencias</h1>
        <button 
          onClick={() => { store.resetFormulario(); setOpenForm(true); }} 
          style={{ background: "#2c3e50", color: "#fff", padding: "10px 20px", border: "none", borderRadius: "5px", cursor: "pointer", fontWeight: "bold" }}
        >
          ➕ Registrar Envío
        </button>
      </div>

      {openForm && (
        <div style={{ position: "fixed", top: 0, left: 0, width: "100%", height: "100%", background: "rgba(0,0,0,0.4)", display: "flex", justifyContent: "center", alignItems: "center", zIndex: 1000 }}>
          <RegistrarTransferencia onClose={() => setOpenForm(false)} />
        </div>
      )}

      {isLoading ? <p>Cargando registros...</p> : (
        <table width="100%" border="1" cellPadding="12" style={{ borderCollapse: "collapse", background: "#fff", border: "1px solid #dee2e6" }}>
          <thead>
            <tr style={{ background: "#2c3e50", color: "#fff", textAlign: "left" }}>
              <th style={{ textAlign: "center" }}>Nº</th>
              <th>Fecha</th>
              <th>Origen</th>
              <th>Destino</th>
              <th style={{ textAlign: "center" }}>Estado</th>
              <th>Observación</th>
              <th style={{ textAlign: "center" }}>Acciones Completas</th>
            </tr>
          </thead>
          <tbody>
  {store.transferencias.map((item) => {
    // Forzamos el texto a mayúsculas limpias para evitar fallos de formato
    const estadoLimpio = item.estado ? item.estado.toUpperCase().trim() : "";
    
    // Descomenta la línea de abajo si quieres ver en la consola F12 exactamente qué texto llega
    // console.log(`Transferencia #${item.id} - Estado real en BD: "${item.estado}" -> Evaluado como: "${estadoLimpio}"`);

    return (
      <tr key={item.id} style={{ borderBottom: "1px solid #dee2e6" }}>
        <td align="center" style={{ fontWeight: "bold" }}>#{item.id}</td>
        <td>{new Date(item.fecha).toLocaleDateString()}</td>
        <td>{item.almacen_origen?.nombre || "-"}</td>
        <td style={{ fontWeight: "500", color: "#27ae60" }}>{item.almacen_destino?.nombre || "-"}</td>
        <td align="center">
          <span style={{ 
            padding: "5px 10px", 
            borderRadius: "15px", 
            fontSize: "11px", 
            fontWeight: "bold",
            color: "#fff",
            background: estadoLimpio === "RECIBIDO" ? "#2ecc71" : "#3498db"
          }}>
            {item.estado || "SIN ESTADO"}
          </span>
        </td>
        <td style={{ color: "#7f8c8d", fontStyle: "italic" }}>{item.observacion || "-"}</td>
        <td align="center">
          <div style={{ display: "flex", gap: "8px", justifyContent: "center" }}>
            
            {/* Opciones activas si la transferencia NO ha sido recibida aún */}
            {estadoLimpio !== "RECIBIDO" ? (
              <>
                <button 
                  onClick={() => handleRecibir(item.id)} 
                  style={{ background: "#2ecc71", color: "#fff", border: "none", padding: "6px 10px", borderRadius: "4px", cursor: "pointer", fontWeight: "bold", fontSize: "11px" }}
                >
                  ✔ Recibir
                </button>

                <button 
                  onClick={() => handleEditar(item)} 
                  style={{ background: "#f39c12", color: "#fff", border: "none", padding: "6px 10px", borderRadius: "4px", cursor: "pointer", fontWeight: "bold", fontSize: "11px" }}
                >
                  ✏ Editar
                </button>
              </>
            ) : (
              <span style={{ color: "#7f8c8d", fontSize: "11px", fontStyle: "italic" }}>Proceso finalizado</span>
            )}

            {/* Eliminar siempre disponible */}
            <button 
              onClick={() => handleEliminar(item.id)} 
              style={{ background: "#e74c3c", color: "#fff", border: "none", padding: "6px 10px", borderRadius: "4px", cursor: "pointer", fontWeight: "bold", fontSize: "11px" }}
            >
              ❌ Eliminar
            </button>

          </div>
        </td>
      </tr>
    );
  })}
</tbody>
        </table>
      )}
    </div>
  );
};
</file>

