  const onGenerateTicket = async (output) => {
    const dataempresa = {
      logo: "https://cdn.forbes.com.mx/2020/03/El-sen%CC%83or-de-los-anillos-Golum-.jpg",
      productos: items,
    };
    const response = await ticket(output, dataempresa);
