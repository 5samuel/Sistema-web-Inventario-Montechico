  let randomCode = "";
  for (let i = 0; i < codeLength; i++) {
    randomCode += characters.charAt(
      Math.floor(Math.random() * characters.length)
    );
  }
  const codigo = `${randomCode}${ultimoIdProducto}369`;
  return codigo;
};
</file>

